# MongoDB connection string (required)
# For local Docker: mongodb://root:example@localhost:27017/nest?authSource=admin
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_URI=mongodb://root:example@localhost:27017/nest?authSource=admin

# Application port (optional, defaults to 3000)
PORT=3000
